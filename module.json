{
    "id": "verglas",
    "name": "Verglas",
    "abbrev": "VRGL",
    "version": "1.1.0",
    "description": "Mutable Instruments Clouds granular processor — granular, stretch, looper, and spectral modes for Ableton Move",
    "author": "Emilie Gillet (DSP) / fillioning (port)",
    "dsp": "verglas.so",
    "api_version": 2,
    "capabilities": {
        "chainable": true,
        "component_type": "audio_fx",
        "audio_in": true,
        "chain_params": [
            {"key": "position",      "name": "Position",  "type": "float", "min": 0,    "max": 1,     "default": 0.5,    "step": 0.01},
            {"key": "size",          "name": "Size",      "type": "float", "min": 0,    "max": 1,     "default": 0.5,    "step": 0.01},
            {"key": "pitch",         "name": "Pitch",     "type": "int",   "min": -24,  "max": 24,    "default": 0,      "step": 1},
            {"key": "density",       "name": "Density",   "type": "float", "min": 0,    "max": 1,     "default": 1.0,    "step": 0.01},
            {"key": "texture",       "name": "Texture",   "type": "float", "min": 0,    "max": 1,     "default": 0.5,    "step": 0.01},
            {"key": "feedback",      "name": "Feedback",  "type": "float", "min": 0,    "max": 1,     "default": 0,      "step": 0.01},
            {"key": "reverb",        "name": "Reverb",    "type": "float", "min": 0,    "max": 1,     "default": 0,      "step": 0.01},
            {"key": "dry_wet",       "name": "Mix",       "type": "float", "min": 0,    "max": 1,     "default": 0.5,    "step": 0.01},
            {"key": "mode",          "name": "Mode",      "type": "enum",  "options": ["Granular", "Stretch", "Looper", "Spectral"], "default": 0},
            {"key": "freeze",        "name": "Freeze",    "type": "enum",  "options": ["Off", "On"], "default": 0},
            {"key": "quality",       "name": "Quality",   "type": "enum",  "options": ["16-bit", "Lo-Fi"], "default": 0},
            {"key": "stereo_spread", "name": "Spread",    "type": "float", "min": 0,    "max": 1,     "default": 1.0,    "step": 0.01},
            {"key": "filter_hp",     "name": "HPF",       "type": "int",   "min": 0,    "max": 1000,  "default": 0,      "step": 10},
            {"key": "filter_lp",     "name": "LPF",       "type": "int",   "min": 1000, "max": 20000, "default": 20000,  "step": 10},
            {"key": "limiter_on",    "name": "Limiter",   "type": "enum",  "options": ["Off", "On"], "default": 0},
            {"key": "limiter_pre",   "name": "Pre Gain",  "type": "float", "min": -6,   "max": 6,     "default": 0,      "step": 0.5},
            {"key": "limiter_post",  "name": "Post Gain", "type": "float", "min": -6,   "max": 6,     "default": 0,      "step": 0.5},
            {"key": "low_boost",    "name": "Low Boost", "type": "float", "min": 0,    "max": 6,     "default": 0,      "step": 0.5},
            {"key": "low_freq",     "name": "Low Freq",  "type": "int",   "min": 30,   "max": 400,   "default": 100,    "step": 10},
            {"key": "low_q",        "name": "Low Q",     "type": "float", "min": 0.1,  "max": 4.0,   "default": 0.7,    "step": 0.1}
        ],
        "ui_hierarchy": {
            "modes": null,
            "levels": {
                "root": {
                    "name": "Verglas",
                    "knobs": ["position", "size", "pitch", "density", "texture", "feedback", "reverb", "dry_wet"],
                    "params": [
                        {"level": "Verglas", "label": "Verglas"},
                        {"level": "Filters", "label": "Filters"}
                    ]
                },
                "Verglas": {
                    "label": "Verglas",
                    "knobs": ["position", "size", "pitch", "density", "texture", "feedback", "reverb", "dry_wet"],
                    "params": ["position", "size", "pitch", "density", "texture", "feedback", "reverb", "dry_wet",
                        "mode", "freeze", "quality", "stereo_spread"]
                },
                "Filters": {
                    "label": "Filters",
                    "knobs": ["filter_hp", "filter_lp", "limiter_on", "limiter_pre", "limiter_post", "low_boost", "low_freq", "low_q"],
                    "params": ["filter_hp", "filter_lp", "limiter_on", "limiter_pre", "limiter_post", "low_boost", "low_freq", "low_q"]
                }
            }
        }
    }
}
