{
    "id": "weird_drum",
    "name": "Weird Drum",
    "abbrev": "WDRM",
    "version": "1.0.0",
    "description": "Analog-style drum synthesizer — oscillator + filtered noise + distortion, inspired by WeirdDrums",
    "author": "dfilaretti (DSP) / fillioning (port)",
    "dsp": "weird_drum.so",
    "ui_chain": "ui_chain.js",
    "api_version": 2,
    "component_type": "audio_fx",
    "capabilities": {
        "chainable": true,
        "component_type": "audio_fx",
        "audio_in": true,
        "chain_params": [
            {"key": "freq",           "name": "Freq",       "type": "float", "min": 20,    "max": 2000,  "default": 55,     "step": 1},
            {"key": "attack",         "name": "Attack",     "type": "float", "min": 0.001, "max": 1,     "default": 0.001,  "step": 0.001},
            {"key": "decay",          "name": "Decay",      "type": "float", "min": 0.001, "max": 2,     "default": 0.5,    "step": 0.01},
            {"key": "wave_type",      "name": "Wave",       "type": "enum",  "options": ["Sine", "Saw", "Square"], "default": 0},
            {"key": "pitch_env_amt",  "name": "P.Env Amt",  "type": "float", "min": 0,     "max": 1,     "default": 0,      "step": 0.01},
            {"key": "pitch_env_rate", "name": "P.Env Rate", "type": "float", "min": 0.001, "max": 1,     "default": 0.1,    "step": 0.001},
            {"key": "pitch_lfo_amt",  "name": "LFO Amt",    "type": "float", "min": 0,     "max": 1,     "default": 0,      "step": 0.01},
            {"key": "pitch_lfo_rate", "name": "LFO Rate",   "type": "float", "min": 0.1,   "max": 80,    "default": 0.45,   "step": 0.1},
            {"key": "filter_type",    "name": "Filter",     "type": "enum",  "options": ["LP", "HP", "BP"], "default": 0},
            {"key": "filter_cutoff",  "name": "Cutoff",     "type": "float", "min": 20,    "max": 18000, "default": 400,    "step": 10},
            {"key": "filter_res",     "name": "Reso",       "type": "float", "min": 0.1,   "max": 5,     "default": 1,      "step": 0.1},
            {"key": "noise_attack",   "name": "N.Attack",   "type": "float", "min": 0.001, "max": 1,     "default": 0.01,   "step": 0.001},
            {"key": "noise_decay",    "name": "N.Decay",    "type": "float", "min": 0.001, "max": 1,     "default": 0.4,    "step": 0.01},
            {"key": "mix",            "name": "Mix",        "type": "float", "min": 0,     "max": 1,     "default": 0.5,    "step": 0.01},
            {"key": "distortion",     "name": "Distort",    "type": "float", "min": 0,     "max": 50,    "default": 0,      "step": 0.5},
            {"key": "level",          "name": "Level",      "type": "float", "min": -96,   "max": 24,    "default": 0,      "step": 0.5},
            {"key": "preset",         "name": "Preset",     "type": "enum",  "options": ["Custom", "Kick", "Snare", "Tom", "Clap", "Rimshot", "Hi Hat", "Cymbal"], "default": 0}
        ],
        "ui_hierarchy": {
            "modes": null,
            "levels": {
                "root": {
                    "name": "Weird Drum",
                    "knobs": ["freq", "attack", "decay", "wave_type", "pitch_env_amt", "pitch_env_rate", "pitch_lfo_amt", "pitch_lfo_rate"],
                    "params": [
                        {"level": "Tone", "label": "Tone"},
                        {"level": "Noise/Master", "label": "Noise/Master"}
                    ]
                },
                "Tone": {
                    "label": "Tone",
                    "knobs": ["freq", "attack", "decay", "wave_type", "pitch_env_amt", "pitch_env_rate", "pitch_lfo_amt", "pitch_lfo_rate"],
                    "params": ["freq", "attack", "decay", "wave_type", "pitch_env_amt", "pitch_env_rate", "pitch_lfo_amt", "pitch_lfo_rate", "preset"]
                },
                "Noise/Master": {
                    "label": "Noise/Master",
                    "knobs": ["filter_type", "filter_cutoff", "filter_res", "noise_attack", "noise_decay", "mix", "distortion", "level"],
                    "params": ["filter_type", "filter_cutoff", "filter_res", "noise_attack", "noise_decay", "mix", "distortion", "level"]
                }
            }
        }
    }
}
